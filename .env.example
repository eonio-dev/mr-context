# Mr. Context — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to source control.

# GitHub personal access token (required for private repositories)
# Scopes needed: repo:read (or public_repo for public-only access)
# Generate at: https://github.com/settings/tokens/new
GITHUB_TOKEN=

# Comma-separated list of repository URLs (alternative to .mrcaconfig)
# MRC_REPOS=https://github.com/org/repo1,https://github.com/org/repo2
MRC_REPOS=
